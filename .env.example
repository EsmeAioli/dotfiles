# .env.example — Optional overrides for Esme's dotfiles setup
# Copy to `.env` and adjust as needed for your own machine


# ── Locale and input ──
LOCALE_LANG=en_GB.UTF-8
VC_KEYMAP=us-intl
X11_LAYOUT=us,gb
X11_VARIANT=intl,''
TIMEZONE=Europe/London


# ── Application install lists ──
# Space-separated Flatpak IDs (from flathub)
FLATPAK_APPS="\
com.spotify.Client \
com.discordapp.Discord \
com.slack.Slack \
org.telegram.desktop \
org.gnome.Boxes \
io.github.dvlv.boxbuddyrs"

# Space-separated RPM package names (from DNF)
RPM_APPS="\
code \
gitkraken \
docker-desktop \
podman-desktop \
thunderbird \
openlens"


# ── GNOME Dock Favourites ──
# Space-separated list of .desktop files to pin to dock
DOCK_ITEMS="\
com.spotify.Client.desktop \
dev.k8slens.OpenLens.desktop \
com.axosoft.GitKraken.desktop \
org.gnome.Boxes.desktop \
org.telegram.desktop.desktop \
com.slack.Slack.desktop \
com.discordapp.Discord.desktop"

# ── Personal credentials ──
ATUIN_USERNAME=your_username_here
ATUIN_KEY=your_api_key_here


# ── Git identity ──
GIT_NAME="Your Name"
GIT_EMAIL="esme@example.com"


# ── Custom configuration sources ──
STARSHIP_REPO_URL=https://github.com/EsmeAioli/pastel-powerline-kate.git